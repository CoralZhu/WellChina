{
  "expo": {
    "name": "WellChina",
    "slug": "wellchina",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "wellchina",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#C0392B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wellchina.app"
    },
    "android": {
      "package": "com.wellchina.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
